<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F8">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <!-- Logo + App Name -->
        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp">

            <View
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_logo_circle" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFF"
                android:contentDescription="Logo" />

        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="WhisperWall"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#6C3CE1" />

        <!-- Username display -->
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User"
            android:textSize="13sp"
            android:textColor="#6C3CE1"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#6C3CE1"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        android:tint="#FFFFFF"
                        android:contentDescription="Welcome icon"
                        android:layout_marginEnd="8dp" />

                    <!-- Dynamic welcome message -->
                    <TextView
                        android:id="@+id/tvWelcomeMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back!"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Share your thoughts anonymously and support others in the community."
                    android:textSize="12sp"
                    android:textColor="#E0D4FF" />

            </LinearLayout>

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:text="Recent Confessions"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#555555" />

            <!-- Confession Card 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:padding="16dp">

                <!-- Category Tag -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mental Health"
                    android:textSize="11sp"
                    android:textColor="#6C3CE1"
                    android:background="@drawable/bg_tag_purple"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginBottom="10dp" />

                <!-- Confession Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I've been feeling really stressed about school lately, but I don't know who to talk to about it. Sometimes I just need to let it out."
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp" />

                <!-- Footer Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/btn_star_big_on"
                        android:tint="#AAAAAA"
                        android:contentDescription="Like" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 24"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_report_image"
                        android:tint="#AAAAAA"
                        android:contentDescription="Report" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Report"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2h ago"
                        android:textSize="12sp"
                        android:textColor="#BBBBBB"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

            <!-- Confession Card 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:padding="16dp">

                <!-- Category Tag -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal"
                    android:textSize="11sp"
                    android:textColor="#6C3CE1"
                    android:background="@drawable/bg_tag_purple"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginBottom="10dp" />

                <!-- Confession Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I secretly love singing in the shower and pretending I'm performing at a concert. It's my favorite part of the day!"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp" />

                <!-- Footer Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/btn_star_big_on"
                        android:tint="#AAAAAA"
                        android:contentDescription="Like" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 42"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_report_image"
                        android:tint="#AAAAAA"
                        android:contentDescription="Report" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Report"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="5h ago"
                        android:textSize="12sp"
                        android:textColor="#BBBBBB"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

            <!-- Confession Card 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                android:padding="16dp">

                <!-- Category Tag -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Relationships"
                    android:textSize="11sp"
                    android:textColor="#6C3CE1"
                    android:background="@drawable/bg_tag_purple"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginBottom="10dp" />

                <!-- Confession Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I wish I had the courage to tell my friend how much they mean to me. They've been there for me through everything."
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp" />

                <!-- Footer Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/btn_star_big_on"
                        android:tint="#AAAAAA"
                        android:contentDescription="Like" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 67"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_report_image"
                        android:tint="#AAAAAA"
                        android:contentDescription="Report" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Report"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1d ago"
                        android:textSize="12sp"
                        android:textColor="#BBBBBB"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Floating Action Button area (Post button) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_fab_purple" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_input_add"
            android:tint="#FFFFFF"
            android:contentDescription="Post confession" />

    </FrameLayout>

</LinearLayout>