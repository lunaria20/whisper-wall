<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- Logo Circle -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">

            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_logo_circle" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFF"
                android:contentDescription="WhisperWall Logo" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Join WhisperWall"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#6C3CE1" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="32dp"
            android:text="Create your anonymous account"
            android:textSize="14sp"
            android:textColor="#888888" />

        <!-- Sign Up Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp">

            <!-- Username Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <!-- Username Input -->
            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Choose a username"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- Email Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <!-- Email Input -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="your@email.com"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- Password Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <!-- Password Input -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="At least 8 characters"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- Confirm Password Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Password"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <!-- Confirm Password Input -->
            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Re-enter password"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <!-- Error Message (hidden by default) -->
            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#E53935"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <!-- Create Account Button -->
            <Button
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Create Account"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button_purple"
                android:layout_marginTop="8dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Anonymous note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:text="Your identity will remain anonymous when posting confessions"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:textAlignment="center" />

        <!-- Already have account -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textSize="14sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log In"
                android:textSize="14sp"
                android:textColor="#6C3CE1"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>