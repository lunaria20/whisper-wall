<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.WhisperWall"
        tools:targetApi="31">

        <!-- LAUNCHER: app opens here first -->
        <activity
            android:name=".features.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Sign Up screen -->
        <activity
            android:name=".features.register.RegisterActivity"
            android:exported="false" />

        <!-- Home / Dashboard screen -->
        <activity
            android:name=".features.home.HomeActivity"
            android:exported="false" />

        <activity
            android:name=".features.home.NewConfessionActivity"
            android:exported="false" />

        <activity
            android:name=".features.home.ReportConfessionActivity"
            android:exported="false" />

        <activity
            android:name=".features.profile.ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".features.moderator.ModeratorActivity"
            android:exported="false" />

        <activity
            android:name=".features.admin.AdminActivity"
            android:exported="false" />

    </application>

</manifest>
